# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com valores reais.

# URL do projeto Supabase
SUPABASE_URL=https://jrmjtfpledyuvwvwigyw.supabase.co

# Chave pública (anon) do Supabase — segura para uso em app com RLS habilitado.
# Encontre em: Supabase Dashboard → Project Settings → API → anon public
SUPABASE_ANON_KEY=sua_anon_key_aqui

# NÃO use a service role key em produção. Ela dá acesso irrestrito ao banco.
# SUPABASE_SERVICE_KEY=apenas_para_testes_locais_nunca_commitar
